# === LLM (OpenAI) ===
OPENAI_API_KEY=sk-REPLACE_ME
# Model for item extraction (step 1) and optional reranking (step 3)
OPENAI_MODEL=gpt-5.2

# === Embedding ===
# Uses local sentence-transformers by default (no API key needed)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# === Retrieval ===
TOP_K=8

# === Data paths ===
USDA_CSV=data/processed/usda_nutrition_clean.csv
OFF_CSV=data/processed/off_nutrition_clean.csv
FAISS_INDEX_DIR=data/vector_store
